# Database
POSTGRES_USER=godsplan
POSTGRES_PASSWORD=godsplan_dev
POSTGRES_DB=godsplan
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# PgAdmin (optional)
PGADMIN_EMAIL=admin@godsplan.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Backend API
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# Scraping
SCRAPE_USER_AGENT=Mozilla/5.0 (compatible; GodsPlan/1.0; +https://godsplan.app)
SCRAPE_INTERVAL_HOURS=24
SCRAPE_TIMEOUT_MS=30000
GOOGLE_PLACES_API_KEY=
GOOGLE_SCRAPER_USE_FIXTURES=false

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
