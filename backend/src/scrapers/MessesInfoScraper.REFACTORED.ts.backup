/**
 * MessesInfoScraper - REFACTORED VERSION
 * 
 * Key improvements:
 * - Memory leak fixes (guaranteed browser cleanup)
 * - Type safety (no 'any' types)
 * - Shared utilities (textNormalizer, addressParser)
 * - Better error handling with ScraperError
 * - Configurable delays
 * - JSDoc documentation
 */

import puppeteer, { Browser, HTTPResponse, Page } from 'puppeteer';
import { BaseScraper, ScrapedChurch } from './BaseScraper';
import { ScraperError, ScraperErrorType } from './utils/types';
import { parseAddress } from './utils/addressParser';
import { normalize } from './utils/textNormalizer';

interface AnnuaireChurchPayload {
  id: string;
  name?: string;
  address?: string;
  zipcode?: string;
  city?: string;
  latitude?: number;
  longitude?: number;
}

interface SeedChurchData {
  name: string;
  address: ScrapedChurch['address'];
  latitude?: number;
  longitude?: number;
}

interface ExtractedSchedule {
  dayOfWeek: number;
  time: string;
  title: string;
  notes?: string;
  tags: string[];
}

interface ExtractedPageData {
  name: string;
  pageText: string;
  addressText?: string;
  phoneText?: string;
  email?: string;
  website?: string;
  schedules: ExtractedSchedule[];
}

/**
 * Day name to number mapping for schedule parsing
 */
const DAY_MAP: Record<string, number> = {
  dim: 0,
  dimanche: 0,
  lun: 1,
  lundi: 1,
  mar: 2,
  mardi: 2,
  mer: 3,
  mercredi: 3,
  jeu: 4,
  jeudi: 4,
  ven: 5,
  vendredi: 5,
  sam: 6,
  samedi: 6,
};

/**
 * Scrapes church data from messes.info using Puppeteer
 * 
 * @remarks
 * Handles GWT-rendered JavaScript pages with comprehensive error handling
 * and guaranteed resource cleanup.
 * 
 * @example
 * ```ts
 * const scraper = new MessesInfoScraper();
 * const churches = await scraper.scrape();
 * // Browser is automatically closed even on errors
 * ```
 */
export class MessesInfoScraper extends BaseScraper {
  private browser: Browser | null = null;
  private listPage: Page | null = null;
  private detailPage: Page | null = null;
  private seedChurches = new Map<string, SeedChurchData>();

  // ✅ Configurable delays (not hardcoded)
  private readonly pageLoadDelayMs: number;
  private readonly suiteButtonDelayMs: number;
  private readonly detailPageDelayMs: number;

  constructor() {
    super({
      name: 'messes.info',
      baseUrl: 'https://www.messes.info',
      rateLimit: Number(process.env.MESSES_INFO_RATE_LIMIT_MS || '500'),
    });

    this.pageLoadDelayMs = Number(process.env.MESSES_PAGE_LOAD_DELAY_MS || '1500');
    this.suiteButtonDelayMs = Number(process.env.MESSES_SUITE_DELAY_MS || '1300');
    this.detailPageDelayMs = Number(process.env.MESSES_DETAIL_DELAY_MS || '900');
  }

  /**
   * Scrapes all churches with guaranteed browser cleanup
   * 
   * @throws {ScraperError} On critical failures
   */
  async scrape(): Promise<ScrapedChurch[]> {
    try {
      return await super.scrape();
    } finally {
      // ✅ CRITICAL: Always close browser
      await this.closeBrowser();
    }
  }

  /**
   * Scrapes church list from messes.info annuaire
   * 
   * @returns Array of church detail page URLs
   */
  async scrapeChurchList(): Promise<string[]> {
    const departmentCode = '75';
    const startUrl = `${this.config.baseUrl}/horaires-messes/${departmentCode}-paris`;
    const annuaireUrl = `${this.config.baseUrl}/annuaire/${departmentCode}`;

    try {
      const page = await this.getListPage();

      // ✅ Typed response handler
      const onResponse = async (response: HTTPResponse): Promise<void> => {
        if (!response.url().includes('/gwtRequest')) {
          return;
        }

        const postData = response.request().postData() || '';
        if (!postData.includes(`"${departmentCode}"`)) {
          return;
        }

        try {
          const body = await response.text();
          const payloads = this.extractAnnuairePayloads(body);
          payloads.forEach((payload) => this.storeSeedChurch(payload));
        } catch {
          // Ignore unrelated GWT calls
        }
      };

      page.on('response', onResponse);

      try {
        // Required URL
        await page.goto(startUrl, { 
          waitUntil: 'networkidle2', 
          timeout: this.config.timeout 
        });

        // Main data source
        await page.goto(annuaireUrl, { 
          waitUntil: 'networkidle2', 
          timeout: this.config.timeout 
        });
        await this.sleep(this.pageLoadDelayMs);

        // Load additional batches
        await this.loadAllSuitePages(page);
      } finally {
        page.off('response', onResponse);
      }

      let urls = Array.from(this.seedChurches.keys());

      // Respect max churches limit
      const maxChurches = Number(process.env.SCRAPE_MAX_CHURCHES || '0');
      if (Number.isFinite(maxChurches) && maxChurches > 0) {
        urls = urls.slice(0, maxChurches);
      }

      return urls;
    } catch (error) {
      throw ScraperError.network(
        'Failed to scrape church list from messes.info',
        error as Error
      );
    }
  }

  /**
   * Scrapes detailed church information from a specific URL
   * 
   * @param url - Church detail page URL
   * @returns Scraped church data or null if scraping fails
   */
  async scrapeChurchDetails(url: string): Promise<ScrapedChurch | null> {
    const seed = this.seedChurches.get(url);

    try {
      const page = await this.getDetailPage();
      await page.goto(url, { 
        waitUntil: 'networkidle2', 
        timeout: this.config.timeout 
      });
      await this.sleep(this.detailPageDelayMs);

      // ✅ Type-safe page evaluation
      const extracted = await this.extractPageData(page);

      const name = extracted.name || seed?.name;
      if (!name) {
        return null;
      }

      const address = this.resolveAddress(extracted.addressText, seed);

      const { languages, rites, massSchedules } = this.processSchedules(
        extracted.schedules,
        extracted.pageText
      );

      return {
        name,
        address,
        latitude: seed?.latitude,
        longitude: seed?.longitude,
        contact: this.buildContact(extracted),
        massSchedules,
        rites: Array.from(rites),
        languages: languages.size > 0 ? Array.from(languages) : ['French'],
        sourceUrl: url,
      };
    } catch (error) {
      console.error(`Failed to scrape details from ${url}:`, error);

      // Fallback to seed data if available
      if (seed) {
        return {
          name: seed.name,
          address: seed.address,
          latitude: seed.latitude,
          longitude: seed.longitude,
          massSchedules: [],
          rites: ['french_paul_vi'],
          languages: ['French'],
          sourceUrl: url,
        };
      }

      return null;
    }
  }

  /**
   * Loads all "Suite..." pages by clicking button repeatedly
   */
  private async loadAllSuitePages(page: Page): Promise<void> {
    for (let i = 0; i < 20; i += 1) {
      const beforeCount = this.seedChurches.size;
      const suiteButton = await this.findSuiteButton(page);
      
      if (!suiteButton) {
        break;
      }

      await page.evaluate((el) => (el as HTMLElement).click(), suiteButton);
      await this.sleep(this.suiteButtonDelayMs);

      // No new data loaded
      if (this.seedChurches.size === beforeCount) {
        break;
      }
    }
  }

  /**
   * Extracts church data from the page DOM
   * 
   * @returns Structured page data (type-safe)
   */
  private async extractPageData(page: Page): Promise<ExtractedPageData> {
    // ✅ Typed evaluation result
    return await page.evaluate((dayMapJson: string) => {
      const dayMap: Record<string, number> = JSON.parse(dayMapJson);
      const doc = document;

      const rawName = doc.querySelector('h1')?.textContent?.trim() || doc.title || '';
      const name = rawName.replace(/\s+-\s+\d{5}.*$/u, '').trim();

      const pageText = doc.body?.innerText || '';

      const addressText =
        doc.querySelector('a.infos-pratique-adresse')?.textContent?.trim() || undefined;

      const phoneMatch = pageText.match(/T[eé]l\.?\s*:?[\s\u00A0]*([+\d][\d\s().-]{7,})/iu);
      const phoneText = phoneMatch?.[1]?.trim() || undefined;

      const email =
        doc
          .querySelector('a[href^="mailto:"]')
          ?.getAttribute('href')
          ?.replace('mailto:', '')
          ?.trim() || undefined;

      const websiteCandidates = Array.from(doc.querySelectorAll('a[href^="http"]'));
      const website =
        websiteCandidates
          .map((a) => a.getAttribute('href') || '')
          .find((href) => {
            const lower = href.toLowerCase();
            return (
              !lower.includes('messes.info') &&
              !lower.includes('google.') &&
              !lower.includes('wikipedia.org')
            );
          }) || undefined;

      const nodes = Array.from(
        doc.querySelectorAll(
          '.com-google-gwt-user-cellview-client-CellTree-Style-cellTreeItemValue > div'
        )
      );

      const schedules: ExtractedSchedule[] = [];
      let currentDay: number | null = null;

      for (const node of nodes) {
        if (node.classList?.contains('titre-date')) {
          const token = (node.textContent || '')
            .trim()
            .toLowerCase()
            .split(/\s+/u)[0]
            ?.replace('.', '');

          if (token && dayMap[token] !== undefined) {
            currentDay = dayMap[token];
          }
          continue;
        }

        if (!node.classList?.contains('egliseinfo-celebrationtime')) {
          continue;
        }

        const title =
          node.querySelector('.egliseinfo-celebrationtime-title')?.textContent?.trim() || '';
        const timeMatch = title.match(/(\d{1,2})\s*h\s*(\d{2})/iu);

        if (!timeMatch || currentDay === null) {
          continue;
        }

        const hh = timeMatch[1].padStart(2, '0');
        const mm = timeMatch[2].padStart(2, '0');

        const tags = Array.from(node.querySelectorAll('.egliseinfo-celebrationtime-tags'))
          .map((el) => el.textContent?.trim())
          .filter(Boolean) as string[];

        const notes =
          node
            .querySelector('.cef-kephas-client-resources-Resources-CSS-egliseInfoCellTreeBody')
            ?.textContent?.trim() || undefined;

        schedules.push({
          dayOfWeek: currentDay,
          time: `${hh}:${mm}`,
          title,
          notes,
          tags,
        });
      }

      return {
        name,
        pageText,
        addressText,
        phoneText,
        email,
        website,
        schedules,
      };
    }, JSON.stringify(DAY_MAP));
  }

  /**
   * Processes mass schedules and extracts rites/languages
   */
  private processSchedules(
    schedules: ExtractedSchedule[],
    pageText: string
  ): {
    languages: Set<string>;
    rites: Set<string>;
    massSchedules: NonNullable<ScrapedChurch['massSchedules']>;
  } {
    const languageSet = new Set<string>();
    const riteSet = new Set<string>();
    const massSchedules: NonNullable<ScrapedChurch['massSchedules']> = [];

    for (const schedule of schedules) {
      const combined = `${schedule.title} ${schedule.notes || ''} ${schedule.tags.join(' ')}`;
      const language = this.inferLanguage(combined);
      const rite = this.inferRite(combined);

      if (language) {
        languageSet.add(language);
      }
      riteSet.add(rite);

      massSchedules.push({
        dayOfWeek: schedule.dayOfWeek,
        time: schedule.time,
        rite,
        language,
        notes: schedule.notes,
      });
    }

    // Extract from page text
    const pageLanguage = this.inferLanguage(pageText);
    if (pageLanguage) {
      languageSet.add(pageLanguage);
    }
    riteSet.add(this.inferRite(pageText));

    return { languages: languageSet, rites: riteSet, massSchedules };
  }

  /**
   * Builds contact object if any contact info exists
   */
  private buildContact(extracted: ExtractedPageData): ScrapedChurch['contact'] | undefined {
    if (!extracted.phoneText && !extracted.email && !extracted.website) {
      return undefined;
    }

    return {
      phone: extracted.phoneText,
      email: extracted.email,
      website: extracted.website,
    };
  }

  /**
   * Extracts annuaire payloads from GWT response
   */
  private extractAnnuairePayloads(body: string): AnnuaireChurchPayload[] {
    try {
      const parsed = JSON.parse(body) as {
        O?: Array<{ P?: Partial<AnnuaireChurchPayload> }>;
      };

      if (!Array.isArray(parsed.O)) {
        return [];
      }

      const rows: AnnuaireChurchPayload[] = [];

      for (const item of parsed.O) {
        const payload = item?.P;
        if (!payload || typeof payload.id !== 'string') {
          continue;
        }

        rows.push({
          id: payload.id,
          name: payload.name,
          address: payload.address,
          zipcode: payload.zipcode,
          city: payload.city,
          latitude: typeof payload.latitude === 'number' ? payload.latitude : undefined,
          longitude: typeof payload.longitude === 'number' ? payload.longitude : undefined,
        });
      }

      return rows;
    } catch {
      return [];
    }
  }

  /**
   * Stores seed church data from annuaire
   */
  private storeSeedChurch(payload: AnnuaireChurchPayload): void {
    const normalizedId = payload.id.startsWith('/') ? payload.id.slice(1) : payload.id;
    const sourceUrl = `${this.config.baseUrl}/lieu/${normalizedId}`;

    if (this.seedChurches.has(sourceUrl)) {
      return;
    }

    this.seedChurches.set(sourceUrl, {
      name: payload.name?.trim() || 'Église inconnue',
      address: {
        street: payload.address?.trim() || '',
        postalCode: payload.zipcode?.trim() || '75000',
        city: payload.city?.trim() || 'Paris',
      },
      latitude: payload.latitude,
      longitude: payload.longitude,
    });
  }

  /**
   * Resolves final address using seed data or parsing
   * 
   * @remarks Uses shared addressParser utility
   */
  private resolveAddress(
    addressText: string | undefined,
    seed: SeedChurchData | undefined
  ): ScrapedChurch['address'] {
    if (seed) {
      return seed.address;
    }

    if (!addressText) {
      return {
        street: '',
        postalCode: '75000',
        city: 'Paris',
      };
    }

    // ✅ Use shared utility
    return parseAddress(addressText, 'Paris', '75000');
  }

  /**
   * Infers rite from text content
   */
  private inferRite(text: string): string {
    const content = normalize(text);

    if (
      content.includes('tridentin') ||
      content.includes('missel de 1962') ||
      content.includes('forme extraordinaire')
    ) {
      return 'latin_traditional';
    }

    if (content.includes('byzantin')) {
      return 'byzantine';
    }

    return 'french_paul_vi';
  }

  /**
   * Infers language from text content
   */
  private inferLanguage(text: string): string | undefined {
    const content = normalize(text);

    const languageMap: Record<string, string> = {
      francais: 'French',
      french: 'French',
      anglais: 'English',
      english: 'English',
      espagnol: 'Spanish',
      spanish: 'Spanish',
      italien: 'Italian',
      italian: 'Italian',
      portugais: 'Portuguese',
      portuguese: 'Portuguese',
      latin: 'Latin',
    };

    for (const [key, value] of Object.entries(languageMap)) {
      if (content.includes(key)) {
        return value;
      }
    }

    return undefined;
  }

  /**
   * Gets or creates browser instance
   */
  private async getBrowser(): Promise<Browser> {
    if (this.browser) {
      return this.browser;
    }

    this.browser = await puppeteer.launch({
      headless: true,
      args: ['--no-sandbox', '--disable-setuid-sandbox'],
    });

    return this.browser;
  }

  /**
   * Gets or creates list page
   */
  private async getListPage(): Promise<Page> {
    if (this.listPage) {
      return this.listPage;
    }

    const browser = await this.getBrowser();
    this.listPage = await browser.newPage();
    this.listPage.setDefaultTimeout(this.config.timeout || 120000);

    return this.listPage;
  }

  /**
   * Gets or creates detail page
   */
  private async getDetailPage(): Promise<Page> {
    if (this.detailPage) {
      return this.detailPage;
    }

    const browser = await this.getBrowser();
    this.detailPage = await browser.newPage();
    this.detailPage.setDefaultTimeout(this.config.timeout || 120000);

    return this.detailPage;
  }

  /**
   * Finds "Suite..." button on page
   */
  private async findSuiteButton(page: Page): Promise<puppeteer.ElementHandle | null> {
    const buttons = await page.$$('button.gwt-Button');

    for (const button of buttons) {
      const label = await button.evaluate((el) => el.textContent?.trim() || '');
      if (normalize(label).startsWith('suite')) {
        return button;
      }
    }

    return null;
  }

  /**
   * Closes all browser resources
   * 
   * @remarks Called automatically in finally block of scrape()
   */
  private async closeBrowser(): Promise<void> {
    if (this.listPage) {
      await this.listPage.close().catch(() => {});
      this.listPage = null;
    }

    if (this.detailPage) {
      await this.detailPage.close().catch(() => {});
      this.detailPage = null;
    }

    if (this.browser) {
      await this.browser.close().catch(() => {});
      this.browser = null;
    }
  }

  /**
   * Sleep utility
   */
  private async sleep(ms: number): Promise<void> {
    await new Promise((resolve) => setTimeout(resolve, ms));
  }
}
