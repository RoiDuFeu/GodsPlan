# GodsPlan Backend - Environment Configuration

# Server
PORT=3001
NODE_ENV=production
API_PREFIX=/api/v1

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=godsplan
POSTGRES_PASSWORD=godsplan_secure_2026
POSTGRES_DB=godsplan_db

# Google Custom Search API (for church website discovery)
# Setup instructions:
# 1. Go to https://console.cloud.google.com/
# 2. Create new project (or select existing)
# 3. Enable "Custom Search API" in API Library
# 4. Create API Key in Credentials
# 5. Create Custom Search Engine at https://programmablesearchengine.google.com/
#    - Configure: "Search the entire web"
#    - Get your Search Engine ID (cx parameter)
# Free tier: 100 queries/day, $5 per 1000 queries after
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Optional: Google Maps API (for geocoding/places)
GOOGLE_MAPS_API_KEY=

# Scraper settings
SCRAPE_USER_AGENT=GodsPlan/1.0 (contact@godsplan.app)
